{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "strict": false,
    "lib": ["ES2022", "DOM"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@sdk/*": ["../../src/*"]
    },
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", "../../src"]
}
